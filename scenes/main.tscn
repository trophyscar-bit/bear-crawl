[sub_resource type="Shader" id="PostShader"]
code = "shader_type canvas_item;
// Full-screen post pass: radial chromatic aberration + animated film grain +
// cinematic vignette. Reads the rendered frame via hint_screen_texture (a
// BackBufferCopy sibling feeds it), processes, and re-outputs opaque so the
// HUD (drawn after) stays crisp and unaffected.
uniform sampler2D screen_tex : hint_screen_texture, filter_linear_mipmap;
uniform float ca_amount : hint_range(0.0, 6.0) = 1.4;     // px shift at frame edge
uniform float grain_amount : hint_range(0.0, 0.2) = 0.035;
uniform float vig_strength : hint_range(0.0, 1.0) = 0.42;
uniform float vig_radius : hint_range(0.0, 1.5) = 0.95;
uniform float vig_softness : hint_range(0.05, 1.2) = 0.65;

float hash(vec2 p) {
	return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

void fragment() {
	vec2 uv = SCREEN_UV;
	vec2 c = uv - 0.5;
	float dist = length(c);
	// Radial CA: offset R/B outward, scaled by dist^2 so the centre stays clean.
	vec2 off = c * dist * (ca_amount * 0.004);
	vec3 col;
	col.r = texture(screen_tex, uv - off).r;
	col.g = texture(screen_tex, uv).g;
	col.b = texture(screen_tex, uv + off).b;
	// Animated film grain.
	float gr = hash(uv * vec2(1920.0, 1080.0) + fract(TIME) * 100.0);
	col += (gr - 0.5) * grain_amount;
	// Vignette (multiplicative darkening toward corners).
	float d = dist * 1.41421356;
	float vig = smoothstep(vig_radius, vig_radius - vig_softness, d);
	col *= mix(1.0 - vig_strength, 1.0, vig);
	COLOR = vec4(col, 1.0);
}
"

